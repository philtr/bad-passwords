<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Bad Passwords" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <style>
      @media (prefers-color-scheme: dark) {
        body {
          background-color: #111;
          color: #eee;
        }

        a {
          color: #8ab4f8;
        }
      }
    </style>
  </head>

  <body bgcolor="whitesmoke">
    <%= yield %>
  </body>
</html>
