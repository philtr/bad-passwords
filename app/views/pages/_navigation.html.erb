<nav aria-label="Primary" class="site-nav">
  <% nav_items = [
    [ "Home", "/" ],
    [ "Docs", "/docs" ],
    [ "Validate", "/validate" ]
  ] %>
  <div class="site-nav-links">
    <% nav_items.each_with_index do |(label, path), index| %>
      <% if current_page?(path) %>
        <span aria-current="page"><%= label %></span>
      <% else %>
        <a href="<%= path %>"><%= label %></a>
      <% end %>
      <% unless index == nav_items.length - 1 %>
        <span aria-hidden="true">|</span>
      <% end %>
    <% end %>
  </div>
</nav>
