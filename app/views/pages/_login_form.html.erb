<fieldset>
  <legend>Login Test</legend>
  <%= form_with url: "/login", method: :post, local: true do |form| %>
    <table>
      <tr>
        <td><label for="login_email">Email</label></td>
        <td><%= form.email_field :email, id: "login_email", value: login_email %></td>
      </tr>
      <tr>
        <td><label for="login_password">Password</label></td>
        <td><%= form.password_field :password, id: "login_password" %></td>
      </tr>
      <tr>
        <td colspan="2"><%= form.submit "Test Login" %></td>
      </tr>
    </table>
  <% end %>
</fieldset>
